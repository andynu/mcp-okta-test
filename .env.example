# Okta issuer URL (Org auth server or Custom auth server)
OKTA_ISSUER=https://yourorg.okta.com

# Expected "aud" claim in the access token
# Org auth server: this is usually https://yourorg.okta.com
# Custom auth server: this is usually api://default
OKTA_AUDIENCE=https://yourorg.okta.com

# Client credentials from the Okta OIDC application
# Used by the OAuth proxy to exchange auth codes for tokens
OKTA_CLIENT_ID=your-client-id
OKTA_CLIENT_SECRET=your-client-secret

# Set to "true" to bypass auth entirely (local dev only!)
# DEV_BYPASS_AUTH=true
